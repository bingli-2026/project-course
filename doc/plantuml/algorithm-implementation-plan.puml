left to right direction
skinparam defaultTextAlignment center
rectangle "视频输入" as v1
rectangle "ROI 选取" as v2
rectangle "Shi-Tomasi 角点提取" as v3
rectangle "LK 光流跟踪/位移重建" as v4
rectangle "滑窗 Welch 特征" as v5
rectangle "视觉特征表" as v6

rectangle "传感器输入" as s1
rectangle "滤波/去直流/分窗" as s2
rectangle "时域/频域统计" as s3
rectangle "传感器特征表" as s4

rectangle "统一窗口对齐" as f1
rectangle "融合特征表" as f2
