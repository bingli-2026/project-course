@startuml
top to bottom direction
skinparam defaultTextAlignment center
skinparam shadowing false
skinparam packageStyle rectangle
skinparam rectangle {
	RoundCorner 12
}

together {
	package "视觉支路" {
		top to bottom direction
		rectangle "视频输入\nROI 选取" as v1
		rectangle "角点跟踪\n位移重建" as v2
		rectangle "视觉位移时序\n时间戳记录" as v3

		v1 --> v2
		v2 --> v3
	}

	package "传感器支路" {
		top to bottom direction
		rectangle "传感器输入\n时间戳记录" as s1
		rectangle "滤波 / 去直流\n振动重建" as s2
		rectangle "传感器时序\n时间戳记录" as s3

		s1 --> s2
		s2 --> s3
	}
}

package "融合与识别" {
	top to bottom direction
	rectangle "时间对齐与\n滑窗融合" as f1
	rectangle "特征提取 / 分类\n增量部署" as f2

	f1 --> f2
}

v3 --> f1
s3 --> f1
v3 -[hidden]-> s3
@enduml
